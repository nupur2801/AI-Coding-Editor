{
  "name": "coding-editor",
  "version": "1.0.0",
  "description": "A terminal-based AI code editor powered by Ollama and React Ink",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coding-editor": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-vm-modules dist/index.js",
    "dev": "tsx src/index.tsx",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "langchain": "^0.3.0",
    "react": "^18.2.0",
    "chalk": "^5.3.0",
    "figures": "^6.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
